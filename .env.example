# ───────────────────────────────────────────────────────────────
# Frontend (Vite) — copy this file to .env.local and fill in.
# Only VITE_-prefixed vars are exposed to the browser.
# ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ───────────────────────────────────────────────────────────────
# Edge Functions (server-side only — set via `supabase secrets set`,
# NEVER prefixed with VITE_, NEVER committed).
# These are listed here for reference only.
# ───────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# LLM_PROVIDER=anthropic            # 'anthropic' now; 'copilot' later
# SUPABASE_SERVICE_ROLE_KEY=...     # auto-provided in deployed functions
